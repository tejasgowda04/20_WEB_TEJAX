# ═══════════════════════════════════════════════════════════════
# EduEvent – Environment Configuration
# Copy this file to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════

# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.onrender.com

# ── Database Configuration ─────────────────────────────────────
# For Render: Use DATABASE_URL (auto-provided)
DATABASE_URL=postgresql://user:password@host:port/dbname

# For Supabase (alternative to DATABASE_URL):
DB_NAME=postgres
DB_USER=postgres.xxxxxxxx
DB_PASSWORD=your-supabase-password
DB_HOST=aws-0-ap-south-1.pooler.supabase.com
DB_PORT=6543

# ── Firebase ───────────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Firebase Web Config (for frontend JS SDK)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── SMTP Email ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EduEvent <your-email@gmail.com>

# ── App Config ─────────────────────────────────────────────────
SITE_URL=http://localhost:8000
COLLEGE_NAME=Your College Name
